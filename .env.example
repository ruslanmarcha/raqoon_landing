# Production origin (no trailing slash). Used for canonical URLs, Open Graph images, and sitemap.xml at build time.
VITE_SITE_URL=https://raqoon.app

# Google Analytics 4 (default in code: G-1S5CS8CFVZ)
# VITE_GTAG_ID=G-1S5CS8CFVZ

# Dev only: simulate EU visitor (consent banner). Set in .env.local
# VITE_DEV_FORCE_EU=1

# Turkey: when `true`, visitors with country TR see only /turkiye. Omit or set to anything else to disable.
# VITE_ENABLE_TURKEY_GEOLOCK=true
